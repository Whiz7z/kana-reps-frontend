# Backend origin (no trailing slash). Required in production — set in Vercel → Settings → Environment Variables.
# Example: https://api.yourdomain.com
VITE_API_URL=http://localhost:3000

# Google Ads: subscription conversion `send_to` — see docs/GOOGLE_ADS_SUBSCRIPTION_CONVERSION.md
# Format: AW-123456789/AbCdEfGhIjKlMnOp (optional — if unset, no conversion is fired)
# VITE_GADS_SUBSCRIPTION_SEND_TO=AW-123456789/xxxxxxxxxx
